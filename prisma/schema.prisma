// Collaborative Learning Tracker Schema
// For Keshav & Dipesh's GFG puzzle + SQL daily tracking

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  name      String
  imageUrl  String?
  createdAt DateTime @default(now())

  puzzles    PuzzleProgress[]
  sqlEntries DailySql[]
  targets    Target[]
}

model Target {
  id          String       @id @default(cuid())
  userId      String
  title       String
  description String?
  deadline    DateTime     @db.Date
  status      TargetStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id])
}

enum TargetStatus {
  PENDING
  COMPLETED
  FAILED
}

model Puzzle {
  id       Int     @id @default(autoincrement())
  title    String
  category String
  link     String?

  progress PuzzleProgress[]
}

model PuzzleProgress {
  id        String   @id @default(cuid())
  userId    String
  puzzleId  Int
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  puzzle Puzzle @relation(fields: [puzzleId], references: [id])

  @@unique([userId, puzzleId])
}

model DailySql {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  completed Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}
